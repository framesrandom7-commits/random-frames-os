generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                @id @default(cuid())
  email               String                @unique
  name                String?
  passwordHash        String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  archivedAt          DateTime?
  createdBy           String?
  updatedBy           String?
  contactEmail        String?
  roleId              String?
  availabilities      Availability[]
  deliveries          Delivery[]
  eventParticipations EventParticipant[]
  financialReports    FinancialReport[]
  followUps           FollowUp[]
  integrationSettings IntegrationSettings[]
  internalNotes       InternalNote[]
  leadsCreated        Lead[]                @relation("LeadCreatedBy")
  leadsUpdated        Lead[]                @relation("LeadUpdatedBy")
  notifications       Notification[]
  tasks               Task[]
  role                Role?                 @relation(fields: [roleId], references: [id])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

model IntegrationSettings {
  id                String    @id @default(cuid())
  provider          String    @unique
  accessToken       String?
  refreshToken      String?
  tokenExpiry       DateTime?
  rootFolderId      String?
  rootFolderUrl     String?
  storageUsageBytes BigInt    @default(0)
  fileCount         Int       @default(0)
  lastSyncAt        DateTime?
  syncStatus        String    @default("IDLE")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  userId            String?
  user              User?     @relation(fields: [userId], references: [id])
}

model WebhookEndpoint {
  id                 String    @id @default(cuid())
  name               String
  url                String
  secret             String?
  eventTypes         String    @default("[]")
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  authenticationType String    @default("HMAC")
  failureCount       Int       @default(0)
  lastFailureAt      DateTime?
  lastSuccessAt      DateTime?
  retryPolicy        String    @default("EXPONENTIAL_BACKOFF")
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id          String           @id @default(cuid())
  action      String           @unique
  description String?
  module      String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  leadTags  LeadTag[]
}

model LeadTag {
  id        String   @id @default(cuid())
  leadId    String
  tagId     String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([leadId, tagId])
}

model Lead {
  id                   String              @id @default(cuid())
  businessName         String
  contactPerson        String?
  phone                String?
  email                String?
  instagram            String?
  website              String?
  address              String?
  city                 String?
  state                String?
  country              String?
  postalCode           String?
  businessType         BusinessType        @default(OTHER)
  leadSource           LeadSource          @default(OTHER)
  status               LeadStatus          @default(NEW)
  priority             LeadPriority        @default(MEDIUM)
  budget               Decimal?            @db.Decimal(10, 2)
  currency             String              @default("USD")
  leadScore            Int                 @default(0)
  notes                String?
  sourceEmailId        String?             @unique
  convertedToClientId  String?             @unique
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  archivedAt           DateTime?
  createdById          String?
  updatedById          String?
  whatsapp             String?
  activities           Activity[]
  calendarEvents       CalendarEvent[]
  communicationsCenter Communication[]
  followUps            FollowUp[]
  internalNotes        InternalNote[]
  convertedToClient    Client?             @relation("LeadConvertedToClient", fields: [convertedToClientId], references: [id])
  createdBy            User?               @relation("LeadCreatedBy", fields: [createdById], references: [id])
  updatedBy            User?               @relation("LeadUpdatedBy", fields: [updatedById], references: [id])
  attachments          LeadAttachment[]
  communications       LeadCommunication[]
  reminders            LeadReminder[]
  leadTags             LeadTag[]
  notifications        Notification[]
  tasks                Task[]
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  description String
  metadata    Json?
  leadId      String?
  clientId    String?
  projectId   String?
  shootId     String?
  invoiceId   String?
  paymentId   String?
  expenseId   String?
  createdAt   DateTime     @default(now())
  createdBy   String?
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  expense     Expense?     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  invoice     Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  payment     Payment?     @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shoot       Shoot?       @relation(fields: [shootId], references: [id], onDelete: Cascade)
}

model LeadCommunication {
  id        String            @id @default(cuid())
  type      CommunicationType
  summary   String
  details   String?
  leadId    String
  clientId  String?
  projectId String?
  createdAt DateTime          @default(now())
  createdBy String?
  lead      Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model LeadReminder {
  id        String       @id @default(cuid())
  type      ReminderType
  date      DateTime
  time      String?
  completed Boolean      @default(false)
  leadId    String
  clientId  String?
  projectId String?
  createdAt DateTime     @default(now())
  createdBy String?
  lead      Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model LeadAttachment {
  id        String   @id @default(cuid())
  fileName  String
  fileUrl   String
  fileSize  Int
  fileType  String
  leadId    String?
  clientId  String?
  projectId String?
  createdAt DateTime @default(now())
  createdBy String?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Client {
  id                   String          @id @default(cuid())
  clientCode           String          @unique
  businessName         String
  contactPerson        String?
  phone                String?
  email                String?
  instagram            String?
  website              String?
  address              String?
  city                 String?
  state                String?
  country              String?
  postalCode           String?
  businessType         BusinessType    @default(OTHER)
  gstNumber            String?
  notes                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  archivedAt           DateTime?
  createdBy            String?
  updatedBy            String?
  driveFolderId        String?
  driveFolderUrl       String?
  activities           Activity[]
  calendarEvents       CalendarEvent[]
  communicationsCenter Communication[]
  expenses             Expense[]
  followUps            FollowUp[]
  internalNotes        InternalNote[]
  invoices             Invoice[]
  convertedFromLead    Lead?           @relation("LeadConvertedToClient")
  notifications        Notification[]
  payments             Payment[]
  projects             Project[]
  quotations           Quotation[]
  shoots               Shoot[]
  tasks                Task[]
}

model Project {
  id                   String          @id @default(cuid())
  projectCode          String          @unique
  title                String
  description          String?
  category             ProjectCategory @default(OTHER)
  status               ProjectStatus   @default(INQUIRY)
  priority             ProjectPriority @default(MEDIUM)
  paymentStatus        PaymentStatus   @default(PENDING)
  startDate            DateTime?
  endDate              DateTime?
  deliveryDate         DateTime?
  quotationAmount      Decimal?        @db.Decimal(10, 2)
  advanceAmount        Decimal?        @db.Decimal(10, 2)
  totalAmount          Decimal?        @db.Decimal(10, 2)
  balanceAmount        Decimal?        @db.Decimal(10, 2)
  profitAmount         Decimal?        @db.Decimal(10, 2)
  notes                String?
  clientId             String
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  archivedAt           DateTime?
  createdBy            String?
  updatedBy            String?
  backupFolderId       String?
  backupFolderUrl      String?
  deliveryFolderId     String?
  deliveryFolderUrl    String?
  documentsFolderId    String?
  documentsFolderUrl   String?
  driveRootFolderId    String?
  driveRootFolderUrl   String?
  editFolderId         String?
  editFolderUrl        String?
  fileCount            Int             @default(0)
  lastSyncAt           DateTime?
  rawFolderId          String?
  rawFolderUrl         String?
  referencesFolderId   String?
  referencesFolderUrl  String?
  socialFolderId       String?
  socialFolderUrl      String?
  storageUsageBytes    BigInt          @default(0)
  syncStatus           String          @default("IDLE")
  activities           Activity[]
  calendarEvents       CalendarEvent[]
  communicationsCenter Communication[]
  deliveries           Delivery[]
  expenses             Expense[]
  followUps            FollowUp[]
  internalNotes        InternalNote[]
  invoices             Invoice[]
  notifications        Notification[]
  payments             Payment[]
  client               Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  quotations           Quotation[]
  reminders            Reminder[]
  shoots               Shoot[]
  tasks                Task[]
}

model Shoot {
  id                    String           @id @default(cuid())
  shootCode             String           @unique
  title                 String
  shootType             ShootType        @default(OTHER)
  status                ShootStatus      @default(PLANNED)
  date                  DateTime?
  startTime             String?
  endTime               String?
  location              String?
  googleMapsLink        String?
  contactPerson         String?
  contactNumber         String?
  photographer          String?
  videographer          String?
  assistants            String?
  weatherNotes          String?
  notes                 String?
  projectId             String
  clientId              String
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  archivedAt            DateTime?
  createdBy             String?
  updatedBy             String?
  callTime              String?
  clientBrief           String?
  deliverablesChecklist String?
  droneOperator         String?
  editor                String?
  makeupArtist          String?
  moodBoard             String?
  referenceImages       String?
  specialRequests       String?
  timeZone              String?
  wrapTime              String?
  audioFolderId         String?
  audioFolderUrl        String?
  btsFolderId           String?
  btsFolderUrl          String?
  cameraAFolderId       String?
  cameraAFolderUrl      String?
  cameraBFolderId       String?
  cameraBFolderUrl      String?
  droneFolderId         String?
  droneFolderUrl        String?
  activities            Activity[]
  calendarEvents        CalendarEvent[]
  deliverables          Deliverable[]
  notifications         Notification[]
  client                Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project               Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  equipment             ShootEquipment[]
  shots                 ShootShot[]
}

model ShootEquipment {
  id      String          @id @default(cuid())
  name    String
  shootId String
  notes   String?
  status  EquipmentStatus @default(REQUIRED)
  shoot   Shoot           @relation(fields: [shootId], references: [id], onDelete: Cascade)
}

model ShootShot {
  id             String  @id @default(cuid())
  title          String
  description    String?
  order          Int     @default(0)
  isCompleted    Boolean @default(false)
  shootId        String
  notes          String?
  priority       String?
  referenceImage String?
  shoot          Shoot   @relation(fields: [shootId], references: [id], onDelete: Cascade)
}

model Deliverable {
  id             String               @id @default(cuid())
  type           String
  assignedEditor String?
  status         DeliverableStatus    @default(PENDING)
  dueDate        DateTime?
  completionDate DateTime?
  shootId        String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  priority       DeliverablePriority  @default(MEDIUM)
  reviewDate     DateTime?
  reviewStatus   ReviewStatus         @default(NOT_SENT)
  reviewerNotes  String?
  shoot          Shoot                @relation(fields: [shootId], references: [id], onDelete: Cascade)
  files          DeliverableFile[]
  versions       DeliverableVersion[]
}

model DeliverableFile {
  id            String      @id @default(cuid())
  deliverableId String
  name          String
  url           String
  sizeBytes     Int?
  uploadedAt    DateTime    @default(now())
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
}

model DeliverableVersion {
  id            String      @id @default(cuid())
  deliverableId String
  versionNumber Int
  changeNotes   String?
  createdBy     String?
  createdAt     DateTime    @default(now())
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
}

model CalendarEvent {
  id                    String               @id @default(cuid())
  title                 String
  date                  DateTime
  startTime             String?
  endTime               String?
  isAllDay              Boolean              @default(false)
  eventType             CalendarEventType
  status                CalendarEventStatus  @default(SCHEDULED)
  color                 String?
  googleCalendarEventId String?
  clientId              String?
  projectId             String?
  shootId               String?
  leadId                String?
  notes                 String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  createdBy             String?
  updatedBy             String?
  recurringRuleId       String?
  client                Client?              @relation(fields: [clientId], references: [id])
  lead                  Lead?                @relation(fields: [leadId], references: [id])
  project               Project?             @relation(fields: [projectId], references: [id])
  recurringRule         RecurringRule?       @relation(fields: [recurringRuleId], references: [id])
  shoot                 Shoot?               @relation(fields: [shootId], references: [id], onDelete: Cascade)
  communicationsCenter  Communication[]
  participants          EventParticipant[]
  internalNotes         InternalNote[]
  reminders             Reminder[]
  resources             ResourceAssignment[]
}

model Invoice {
  id                   String          @id @default(cuid())
  invoiceNumber        String          @unique
  issueDate            DateTime
  dueDate              DateTime
  subtotal             Decimal         @db.Decimal(10, 2)
  discount             Decimal?        @db.Decimal(10, 2)
  tax                  Decimal?        @db.Decimal(10, 2)
  total                Decimal         @db.Decimal(10, 2)
  status               InvoiceStatus   @default(DRAFT)
  notes                String?
  projectId            String
  clientId             String
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  activities           Activity[]
  communicationsCenter Communication[]
  internalNotes        InternalNote[]
  client               Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project              Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items                InvoiceItem[]
  notifications        Notification[]
  payments             Payment[]
}

model Payment {
  id                   String          @id @default(cuid())
  amount               Decimal         @db.Decimal(10, 2)
  paymentDate          DateTime
  paymentMethod        PaymentMethod   @default(OTHER)
  referenceNumber      String?
  notes                String?
  invoiceId            String?
  projectId            String
  clientId             String
  createdAt            DateTime        @default(now())
  bankReference        String?
  paymentScreenshotUrl String?
  upiTransactionId     String?
  activities           Activity[]
  communicationsCenter Communication[]
  internalNotes        InternalNote[]
  client               Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoice              Invoice?        @relation(fields: [invoiceId], references: [id])
  project              Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Expense {
  id            String          @id @default(cuid())
  title         String
  amount        Decimal         @db.Decimal(10, 2)
  date          DateTime
  paymentMethod PaymentMethod   @default(OTHER)
  notes         String?
  clientId      String?
  projectId     String
  createdAt     DateTime        @default(now())
  categoryId    String
  receiptUrl    String?
  vendor        String?
  activities    Activity[]
  category      ExpenseCategory @relation(fields: [categoryId], references: [id])
  client        Client?         @relation(fields: [clientId], references: [id])
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ExpenseCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  color       String?   @default("#888888")
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expenses    Expense[]
}

model Quotation {
  id                   String          @id @default(cuid())
  quotationNumber      String          @unique
  issueDate            DateTime
  validUntil           DateTime
  subtotal             Decimal         @db.Decimal(10, 2)
  discount             Decimal?        @db.Decimal(10, 2)
  tax                  Decimal?        @db.Decimal(10, 2)
  total                Decimal         @db.Decimal(10, 2)
  status               QuotationStatus @default(DRAFT)
  notes                String?
  termsAndConditions   String?
  version              Int             @default(1)
  parentQuotationId    String?
  projectId            String
  clientId             String
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  communicationsCenter Communication[]
  internalNotes        InternalNote[]
  client               Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  parentQuotation      Quotation?      @relation("QuotationVersions", fields: [parentQuotationId], references: [id])
  childQuotations      Quotation[]     @relation("QuotationVersions")
  project              Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items                QuotationItem[]
}

model QuotationItem {
  id          String    @id @default(cuid())
  description String
  quantity    Int       @default(1)
  unitPrice   Decimal   @db.Decimal(10, 2)
  total       Decimal   @db.Decimal(10, 2)
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model InvoiceItem {
  id          String  @id @default(cuid())
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model FinancialReport {
  id          String              @id @default(cuid())
  title       String
  type        FinancialReportType
  periodStart DateTime
  periodEnd   DateTime
  data        Json
  fileUrl     String?
  generatedBy String?
  createdAt   DateTime            @default(now())
  user        User?               @relation(fields: [generatedBy], references: [id])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Notification {
  id           String               @id @default(cuid())
  title        String
  message      String?
  type         NotificationType
  status       NotificationStatus   @default(PENDING)
  priority     NotificationPriority @default(MEDIUM)
  dueDate      DateTime?
  snoozedUntil DateTime?
  leadId       String?
  clientId     String?
  projectId    String?
  shootId      String?
  invoiceId    String?
  userId       String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  actionUrl    String?
  isRead       Boolean              @default(false)
  client       Client?              @relation(fields: [clientId], references: [id])
  invoice      Invoice?             @relation(fields: [invoiceId], references: [id])
  lead         Lead?                @relation(fields: [leadId], references: [id])
  project      Project?             @relation(fields: [projectId], references: [id])
  shoot        Shoot?               @relation(fields: [shootId], references: [id])
  user         User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BackgroundJob {
  id          String    @id @default(cuid())
  type        String
  payload     Json?
  status      JobStatus @default(QUEUED)
  progress    Int       @default(0)
  error       String?
  retryCount  Int       @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  module     String?
  entityId   String?
  entityType String?
  userId     String?
  metadata   Json?
  createdAt  DateTime @default(now())
}

model Task {
  id                      String          @id @default(cuid())
  title                   String
  description             String?
  status                  TaskStatus      @default(PENDING)
  priority                TaskPriority    @default(MEDIUM)
  dueDate                 DateTime?
  estimatedDuration       Int?
  actualDuration          Int?
  progress                Int             @default(0)
  projectId               String?
  clientId                String?
  leadId                  String?
  assignedToId            String?
  parentTaskId            String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  createdBy               String?
  updatedBy               String?
  checklist               ChecklistItem[]
  reminders               Reminder[]
  assignedTo              User?           @relation(fields: [assignedToId], references: [id])
  client                  Client?         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead                    Lead?           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  parentTask              Task?           @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks                Task[]          @relation("SubTasks")
  project                 Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Task_TaskDependencies_A Task[]          @relation("TaskDependencies")
  Task_TaskDependencies_B Task[]          @relation("TaskDependencies")
}

model ChecklistItem {
  id          String   @id @default(cuid())
  title       String
  isCompleted Boolean  @default(false)
  taskId      String
  createdAt   DateTime @default(now())
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Reminder {
  id          String          @id @default(cuid())
  title       String
  description String?
  triggerDate DateTime
  type        ReminderChannel @default(IN_APP)
  isSent      Boolean         @default(false)
  eventId     String?
  taskId      String?
  projectId   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  event       CalendarEvent?  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  project     Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task        Task?           @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Availability {
  id        String   @id @default(cuid())
  userId    String?
  date      DateTime
  reason    String?
  startTime String?
  endTime   String?
  isBlocked Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
}

model WorkingHours {
  id        String  @id @default(cuid())
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean @default(true)
}

model Holiday {
  id       String   @id @default(cuid())
  name     String
  date     DateTime
  isYearly Boolean  @default(false)
}

model EventParticipant {
  id      String            @id @default(cuid())
  eventId String
  userId  String?
  name    String?
  email   String?
  status  ParticipantStatus @default(PENDING)
  event   CalendarEvent     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User?             @relation(fields: [userId], references: [id])
}

model RecurringRule {
  id        String             @id @default(cuid())
  frequency RecurringFrequency
  interval  Int                @default(1)
  endDate   DateTime?
  count     Int?
  events    CalendarEvent[]
}

model Resource {
  id          String               @id @default(cuid())
  name        String
  type        ResourceType         @default(OTHER)
  description String?
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  assignments ResourceAssignment[]
}

model ResourceAssignment {
  id         String        @id @default(cuid())
  resourceId String
  eventId    String
  status     String        @default("ASSIGNED")
  event      CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  resource   Resource      @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

model CommunicationTemplate {
  id        String            @id @default(cuid())
  title     String
  category  TemplateCategory  @default(CUSTOM)
  type      CommunicationType
  subject   String?
  body      String
  version   Int               @default(1)
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  createdBy String?
}

model Communication {
  id          String                    @id @default(cuid())
  type        CommunicationType
  direction   CommunicationDirection
  subject     String?
  body        String
  status      String                    @default("SENT")
  error       String?
  leadId      String?
  clientId    String?
  projectId   String?
  invoiceId   String?
  quotationId String?
  paymentId   String?
  eventId     String?
  sentAt      DateTime                  @default(now())
  createdBy   String?
  client      Client?                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  event       CalendarEvent?            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invoice     Invoice?                  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lead        Lead?                     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  payment     Payment?                  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  project     Project?                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  quotation   Quotation?                @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  attachments CommunicationAttachment[]
  followUps   FollowUp[]
}

model CommunicationAttachment {
  id              String        @id @default(cuid())
  fileName        String
  fileUrl         String
  fileSize        Int
  fileType        String
  communicationId String
  createdAt       DateTime      @default(now())
  communication   Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)
}

model FollowUp {
  id              String         @id @default(cuid())
  title           String
  description     String?
  dueDate         DateTime
  status          FollowUpStatus @default(PENDING)
  priority        String         @default("MEDIUM")
  communicationId String?
  leadId          String?
  clientId        String?
  projectId       String?
  assignedToId    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdBy       String?
  assignedTo      User?          @relation(fields: [assignedToId], references: [id])
  client          Client?        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  communication   Communication? @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  lead            Lead?          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  project         Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Delivery {
  id           String            @id @default(cuid())
  title        String
  description  String?
  status       DeliveryStatus    @default(DRAFT)
  deliveryLink String?
  password     String?
  expiryDate   DateTime?
  projectId    String
  sentAt       DateTime?
  viewedAt     DateTime?
  downloadedAt DateTime?
  confirmedAt  DateTime?
  createdById  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  createdBy    User?             @relation(fields: [createdById], references: [id])
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions     DeliveryVersion[]
}

model DeliveryVersion {
  id           String   @id @default(cuid())
  version      Int
  changes      String?
  deliveryLink String
  deliveryId   String
  createdAt    DateTime @default(now())
  delivery     Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

model InternalNote {
  id          String         @id @default(cuid())
  content     String
  isPinned    Boolean        @default(false)
  leadId      String?
  clientId    String?
  projectId   String?
  invoiceId   String?
  quotationId String?
  paymentId   String?
  eventId     String?
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  client      Client?        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy   User?          @relation(fields: [createdById], references: [id])
  event       CalendarEvent? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invoice     Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lead        Lead?          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  payment     Payment?       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  quotation   Quotation?     @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

