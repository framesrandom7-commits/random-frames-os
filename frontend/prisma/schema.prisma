// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  ATTENDED
  REQUIREMENT_DISCUSSION
  QUOTATION_SENT
  NEGOTIATION
  QUOTATION_ACCEPTED
  CLIENT_FORM_SENT
  CLIENT_FORM_RECEIVED
  CONVERTED_TO_CLIENT
  PROJECT_CREATED
  FIRST_SHOOT_SCHEDULED
  COMPLETED
  CLOSED_LOST
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LeadSource {
  WEBSITE
  MANUAL
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  REFERRAL
  WALK_IN
  COLD_CALL
  EMAIL
  OTHER
}

enum BusinessType {
  CORPORATE
  WEDDING
  FASHION
  REAL_ESTATE
  EVENTS
  COMMERCIAL
  PORTRAIT
  OTHER
}

enum ProjectCategory {
  CAFE
  REAL_ESTATE
  EVENT
  PRODUCT
  OTHER
}

enum ProjectStatus {
  INQUIRY
  PLANNED
  SHOOTING
  EDITING
  REVIEW
  DELIVERED
  COMPLETED
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
  CARD
  OTHER
}

enum ExpenseCategory {
  CLIENT_EXPENSE
  TRAVEL
  FUEL
  FOOD
  EQUIPMENT_RENTAL
  ASSISTANT
  MISCELLANEOUS
}

enum ShootEditingStatus {
  PENDING
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum ShootDeliveryStatus {
  PENDING
  PARTIAL
  DELIVERED
}

enum ShootApprovalStatus {
  PENDING
  CHANGES_REQUESTED
  APPROVED
}

enum ShootType {
  CAFE
  PRODUCT
  REAL_ESTATE
  EVENT
  PORTRAIT
  OTHER
}

enum ShootStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  POSTPONED
}

enum ActivityType {
  NOTE
  STATUS_CHANGE
  FILE_UPLOAD
  SYSTEM
}

enum CommunicationType {
  EMAIL
  CALL
  MEETING
  MESSAGE
}

enum ReminderType {
  FOLLOW_UP
  MEETING
  CALL
  DEADLINE
}

enum Role {
  ADMIN
  MANAGER
  EDITOR
  VIEWER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          Role      @default(VIEWER)
  passwordHash  String
  
  // Enterprise fields
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  archivedAt    DateTime?
  createdBy     String?
  updatedBy     String?

  leadsCreated  Lead[]    @relation("LeadCreatedBy")
  leadsUpdated  Lead[]    @relation("LeadUpdatedBy")
  notifications Notification[]
}

model Tag {
  id          String    @id @default(cuid())
  name        String    @unique
  color       String?
  
  leadTags    LeadTag[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model LeadTag {
  id        String   @id @default(cuid())
  leadId    String
  tagId     String
  
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([leadId, tagId])
}

model Lead {
  id            String       @id @default(cuid())
  businessName  String
  contactPerson String?
  phone         String?
  email         String?
  instagram     String?
  website       String?
  
  address       String?
  city          String?
  state         String?
  country       String?
  postalCode    String?
  
  businessType  BusinessType @default(OTHER)
  leadSource    LeadSource   @default(OTHER)
  status        LeadStatus   @default(NEW)
  priority      LeadPriority @default(MEDIUM)
  
  budget        Decimal?     @db.Decimal(10, 2)
  currency      String       @default("USD")
  
  leadScore     Int          @default(0)
  
  leadTags      LeadTag[]
  
  notes         String?
  
  // Integration fields
  sourceEmailId String?      @unique
  
  convertedToClientId String? @unique
  convertedToClient   Client? @relation("LeadConvertedToClient", fields: [convertedToClientId], references: [id])
  
  activities     Activity[]
  communications LeadCommunication[]
  reminders      LeadReminder[]
  attachments    LeadAttachment[]
  calendarEvents CalendarEvent[]

  
  // Enterprise fields
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  archivedAt    DateTime?
  
  createdById   String?
  createdBy     User?        @relation("LeadCreatedBy", fields: [createdById], references: [id])
  
  updatedById   String?
  updatedBy     User?        @relation("LeadUpdatedBy", fields: [updatedById], references: [id])
  notifications Notification[]
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  description String
  metadata    Json?
  
  leadId      String?
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  clientId    String?
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  shootId     String?
  shoot       Shoot?       @relation(fields: [shootId], references: [id], onDelete: Cascade)
  
  invoiceId   String?
  invoice     Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  paymentId   String?
  payment     Payment?     @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  
  expenseId   String?
  expense     Expense?     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime     @default(now())
  createdBy   String?
}

model LeadCommunication {
  id          String             @id @default(cuid())
  type        CommunicationType
  summary     String
  details     String?
  
  leadId      String
  lead        Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  clientId    String?
  projectId   String?
  
  createdAt   DateTime           @default(now())
  createdBy   String?
}

model LeadReminder {
  id          String       @id @default(cuid())
  type        ReminderType
  date        DateTime
  time        String?
  completed   Boolean      @default(false)
  
  leadId      String
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  clientId    String?
  projectId   String?
  
  createdAt   DateTime     @default(now())
  createdBy   String?
}

model LeadAttachment {
  id          String       @id @default(cuid())
  fileName    String
  fileUrl     String
  fileSize    Int
  fileType    String
  
  leadId      String?
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  clientId    String?
  projectId   String?
  
  createdAt   DateTime     @default(now())
  createdBy   String?
}

model Client {
  id            String       @id @default(cuid())
  clientCode    String       @unique
  businessName  String
  contactPerson String?
  phone         String?
  email         String?
  instagram     String?
  website       String?
  
  address       String?
  city          String?
  state         String?
  country       String?
  postalCode    String?
  
  businessType  BusinessType @default(OTHER)
  gstNumber     String?
  notes         String?
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  archivedAt    DateTime?
  createdBy     String?
  updatedBy     String?
  
  convertedFromLead Lead?    @relation("LeadConvertedToClient")
  projects          Project[]
  shoots            Shoot[]
  calendarEvents    CalendarEvent[]
  invoices          Invoice[]
  payments          Payment[]
  expenses          Expense[]
  notifications     Notification[]
  activities        Activity[]
}

model Project {
  id              String          @id @default(cuid())
  projectCode     String          @unique
  title           String
  description     String?
  
  category        ProjectCategory @default(OTHER)
  status          ProjectStatus   @default(INQUIRY)
  priority        ProjectPriority @default(MEDIUM)
  paymentStatus   PaymentStatus   @default(PENDING)
  
  startDate       DateTime?
  endDate         DateTime?
  deliveryDate    DateTime?
  
  quotationAmount Decimal?        @db.Decimal(10, 2)
  advanceAmount   Decimal?        @db.Decimal(10, 2)
  totalAmount     Decimal?        @db.Decimal(10, 2)
  balanceAmount   Decimal?        @db.Decimal(10, 2)
  profitAmount    Decimal?        @db.Decimal(10, 2)
  
  notes           String?
  
  // Integration fields
  googleDriveFolderId String?
  googleDriveLink     String?
  
  clientId        String
  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  archivedAt      DateTime?
  createdBy       String?
  updatedBy       String?
  
  shoots          Shoot[]
  calendarEvents  CalendarEvent[]
  invoices        Invoice[]
  payments        Payment[]
  expenses        Expense[]
  notifications   Notification[]
  activities      Activity[]
}

model Shoot {
  id              String          @id @default(cuid())
  shootCode       String          @unique
  title           String
  shootType       ShootType       @default(OTHER)
  status          ShootStatus     @default(SCHEDULED)
  
  date            DateTime?
  startTime       String?
  endTime         String?
  
  location        String?
  googleMapsLink  String?
  
  contactPerson   String?
  contactNumber   String?
  deliverables    String?
  
  photographer    String?
  videographer    String?
  assistants      String?
  
  clientRequirements String?
  weatherNotes    String?
  notes           String?
  
  editingStatus   ShootEditingStatus  @default(PENDING)
  deliveryStatus  ShootDeliveryStatus @default(PENDING)
  approvalStatus  ShootApprovalStatus @default(PENDING)
  deliveredDate   DateTime?
  
  projectId       String
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  clientId        String
  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  equipment       ShootEquipment[]
  shots           ShootShot[]
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  archivedAt      DateTime?
  createdBy       String?
  updatedBy       String?
  
  calendarEvents  CalendarEvent[]
  notifications   Notification[]
  activities      Activity[]
}

model ShootEquipment {
  id          String   @id @default(cuid())
  name        String
  isCompleted Boolean  @default(false)
  
  shootId     String
  shoot       Shoot    @relation(fields: [shootId], references: [id], onDelete: Cascade)
}

model ShootShot {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int      @default(0)
  isCompleted Boolean  @default(false)
  
  shootId     String
  shoot       Shoot    @relation(fields: [shootId], references: [id], onDelete: Cascade)
}

enum CalendarEventType {
  SHOOT
  MEETING
  FOLLOW_UP
  DELIVERY
  PAYMENT_DUE
  PERSONAL_REMINDER
}

enum CalendarEventStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  startTime   String?
  endTime     String?
  isAllDay    Boolean  @default(false)
  eventType   CalendarEventType
  status      CalendarEventStatus @default(SCHEDULED)
  color       String?
  
  // Integration fields
  googleCalendarEventId String?
  
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  shootId     String?
  shoot       Shoot?   @relation(fields: [shootId], references: [id], onDelete: Cascade)
  
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  
  notes       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  
  issueDate       DateTime
  dueDate         DateTime
  
  subtotal        Decimal       @db.Decimal(10, 2)
  discount        Decimal?      @db.Decimal(10, 2)
  tax             Decimal?      @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  
  status          InvoiceStatus @default(DRAFT)
  notes           String?
  
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  payments        Payment[]
  notifications   Notification[]
  activities      Activity[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Payment {
  id              String        @id @default(cuid())
  amount          Decimal       @db.Decimal(10, 2)
  paymentDate     DateTime
  paymentMethod   PaymentMethod @default(OTHER)
  referenceNumber String?
  notes           String?
  
  invoiceId       String?
  invoice         Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime      @default(now())
  activities      Activity[]
}

model Expense {
  id              String          @id @default(cuid())
  title           String
  category        ExpenseCategory @default(MISCELLANEOUS)
  amount          Decimal         @db.Decimal(10, 2)
  date            DateTime
  paymentMethod   PaymentMethod   @default(OTHER)
  notes           String?
  
  clientId        String?
  client          Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  projectId       String
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime        @default(now())
  activities      Activity[]
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

enum NotificationType {
  LEAD_FOLLOW_UP
  SHOOT_REMINDER
  MEETING_REMINDER
  PROJECT_DEADLINE
  DELIVERY_REMINDER
  INVOICE_DUE
  PAYMENT_RECEIVED
  OVERDUE_PAYMENT
  GENERAL_REMINDER
}

enum NotificationStatus {
  PENDING
  COMPLETED
  DISMISSED
  SNOOZED
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Notification {
  id        String             @id @default(cuid())
  title     String
  message   String?
  type      NotificationType
  status    NotificationStatus @default(PENDING)
  priority  NotificationPriority @default(MEDIUM)
  
  dueDate   DateTime?
  snoozedUntil DateTime?
  
  // Relations to other entities for Drill Down
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  shootId   String?
  shoot     Shoot?   @relation(fields: [shootId], references: [id], onDelete: SetNull)
  
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
